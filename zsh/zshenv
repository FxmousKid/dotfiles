#!/usr/bin/env zsh
# =============================================================================
#  ~/.zshenv  —  sourced for EVERY zsh (login, interactive, and scripts).
#
#  Keep this fast and side-effect free: environment variables and PATH only.
#  Interactive-only setup  -> ~/.zshrc
#  Login-only setup (brew) -> ~/.zprofile
# =============================================================================

# --- XDG base directories ----------------------------------------------------
export XDG_CONFIG_HOME="$HOME/.config"
export XDG_DATA_HOME="$HOME/.local/share"
export XDG_CACHE_HOME="$HOME/.cache"
export XDG_MUSIC_DIR="$HOME/Music"

# --- zsh ---------------------------------------------------------------------
export ZDOTDIR="$XDG_CONFIG_HOME/zsh"
export HISTFILE="$ZDOTDIR/zsh_history"

# --- Custom roots ------------------------------------------------------------
export RELEASES="$HOME/Releases"          # prebuilt binaries / version managers

# --- Toolchains --------------------------------------------------------------
# Go
export GOPATH="$RELEASES/go"
export GOBIN="$RELEASES/go/bin"
export GOCACHE="$XDG_CACHE_HOME/go-build"
# Node / pnpm / npm
export PNPM_HOME="$XDG_DATA_HOME/pnpm"
export NPM_PATH="$XDG_CONFIG_HOME/node_modules"
export NPM_BIN="$NPM_PATH/bin"
# mpd
export MPD_HOST="$XDG_CONFIG_HOME/mpd/socket"
# zellij
export ZELLIJ_CONFIG_DIR="$XDG_CONFIG_HOME/zellij"

# --- PATH --------------------------------------------------------------------
# `typeset -U` keeps the path array de-duplicated no matter how many times this
# runs — so PATH can never grow on repeated shells/sources. Only existing
# directories are added (no dead entries).
#
# Defined as a function because macOS /etc/zprofile runs `path_helper`, which
# rebuilds PATH and DROPS custom entries. We call it here (so scripts and Linux
# get PATH straight away) AND again from ~/.zprofile (after path_helper) so our
# directories survive and win on macOS login shells.
typeset -U path PATH
zsh_prepend_paths() {
  local dir
  for dir in \
    "$HOME/.atuin/bin" \
    "$HOME/.config/bin" \
    "$HOME/.local/share/zap" \
    "$HOME/.yazi/target/release" \
    "$GOBIN" \
    "$PNPM_HOME"; do
    [[ -n "$dir" && -d "$dir" ]] && path=("$dir" $path)
  done
  [[ -n "$JAVA_HOME" && -d "$JAVA_HOME/bin" ]] && path=("$JAVA_HOME/bin" $path)

  # Device-specific PATHs (version-pinned nvim, etc.) live in hosts/<device>.zsh,
  # which ~/.zshrc sources afterwards — kept out of here so machines don't clash.

  # Highest priority: user-local binaries.
  [[ -d "$HOME/.local/bin" ]] && path=("$HOME/.local/bin" $path)
}
zsh_prepend_paths

# --- Default editor (after PATH so lvim/nvim are resolvable) ------------------
if   command -v lvim &>/dev/null; then export EDITOR="$(command -v lvim)"
elif command -v nvim &>/dev/null; then export EDITOR="$(command -v nvim)"
elif command -v vim  &>/dev/null; then export EDITOR=vim
fi
export VISUAL="$EDITOR"

# --- Rust / Cargo ------------------------------------------------------------
[[ -f "$HOME/.cargo/env" ]] && . "$HOME/.cargo/env"

# --- GPG (interactive only; avoids a tty lookup in scripts) ------------------
[[ -o interactive ]] && export GPG_TTY="$TTY"

# --- OS key + per-machine fingerprint ----------------------------------------
case "$OSTYPE" in
  darwin*) export ZSH_OS=darwin ;;
  linux*)  export ZSH_OS=linux  ;;
  *)       export ZSH_OS=other  ;;
esac

# Stable, non-sensitive machine fingerprint: a truncated hash of a hardware id.
# Only the HASH is ever committed (see device_name), never the raw id.
get_device_id() {
  local raw
  case "$OSTYPE" in
    darwin*) raw="$(ioreg -rd1 -c IOPlatformExpertDevice 2>/dev/null | awk -F'"' '/IOPlatformUUID/{print $4}')" ;;
    linux*)  raw="$(cat /etc/machine-id 2>/dev/null)" ;;
  esac
  [[ -n "$raw" ]] || raw="$(uname -n)"
  if command -v sha256sum >/dev/null 2>&1; then
    printf '%s' "$raw" | sha256sum     | cut -c1-12
  else
    printf '%s' "$raw" | shasum -a 256 | cut -c1-12
  fi
}

# Map known device ids -> friendly host names. To add a machine: run
# `get_device_id`, paste the hash below, and create hosts/<name>.zsh.
device_name() {
  case "$(get_device_id)" in
    12fb04826cee) printf macm1 ;;
    # <asahi-hash>) printf asahim1 ;;
    *)             printf unknown ;;
  esac
}
