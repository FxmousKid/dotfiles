{
    "description": "Swap Left Command ⌘ and Left Control ^ only in Alacritty",
    "manipulators": [
        {
            "conditions": [
                {
                    "bundle_identifiers": [
                        "^org\\.alacritty$"
                    ],
                    "type": "frontmost_application_if"
                }
            ],
            "from": { "key_code": "left_command" },
            "to": [{ "key_code": "left_control" }],
            "type": "basic"
        },
        {
            "conditions": [
                {
                    "bundle_identifiers": [
                        "^org\\.alacritty$"
                    ],
                    "type": "frontmost_application_if"
                }
            ],
            "from": { "key_code": "left_control" },
            "to": [{ "key_code": "left_command" }],
            "type": "basic"
        }
    ]
}
